{
  "$schema": "../config.schema.json",
  "_profile": "developer",
  "_description": "Code + docs + scratch space. Tighter exclude list for dev cruft, shorter retention since code lives in git anyway. Good for day-to-day coding sessions.",
  "roots": [
    { "name": "repos",   "path": "~/code",     "writable": true },
    { "name": "scratch", "path": "~/tmp",      "writable": true },
    { "name": "notes",   "path": "~/Notes",    "writable": true }
  ],
  "exclude_patterns": [
    "**/node_modules/**",
    "**/.git/**",
    "**/.venv/**",
    "**/__pycache__/**",
    "**/.mcpdocs/**",
    "**/dist/**",
    "**/build/**",
    "**/.next/**",
    "**/.nuxt/**",
    "**/.cache/**",
    "**/.parcel-cache/**",
    "**/.turbo/**",
    "**/target/**",
    "**/coverage/**",
    "**/htmlcov/**",
    "**/.pytest_cache/**",
    "**/.mypy_cache/**",
    "**/.ruff_cache/**",
    "**/.tox/**",
    "**/.gradle/**",
    "**/*.egg-info/**",
    "**/vendor/**",
    "**/.idea/**",
    "**/.vscode/**"
  ],
  "max_file_size_mb": 25,
  "versioning": {
    "enabled": true,
    "storage_mode": "flexible",
    "retention_days": 14,
    "max_versions_per_file": 20
  },
  "audit": { "enabled": true, "log_path": null },
  "transport": { "stdio": true, "http": { "enabled": false } },
  "safety": {
    "allow_sensitive": false,
    "follow_symlinks": false,
    "validate_roundtrip_writes": true
  }
}
